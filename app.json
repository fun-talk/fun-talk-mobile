{
  "expo": {
    "name": "欧波开心学",
    "slug": "fun-talk-mobile",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./icons/png216x216.png",
    "scheme": [
      "funtalkmobile",
      "wx4f3da33035cc1d14"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./icons/png216x216.png",
      "bundleIdentifier": "com.anonymous.funtalkmobile",
      "requireFullScreen": true,
      "associatedDomains": [
        "applinks:ai-fun-talk.com",
        "applinks:ai-fun-talk.com"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FunTalk needs microphone access for speaking exercises in lessons.",
        "NSCameraUsageDescription": "FunTalk may use the camera during interactive lessons.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./icons/png216x216.png",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.funtalk"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-wechat-no-pay",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5db2c1d4-0128-4575-bf32-993e20e3164a"
      }
    }
  }
}
