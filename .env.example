# API base URL (no trailing slash). Dev default: local backend on port 9000.
EXPO_PUBLIC_API_HOST=http://localhost:9000
# Android emulator: http://10.0.2.2:9000
# Physical device: your Mac LAN IP, e.g. http://192.168.1.108:9000

# Web app origin used for Phase 5 WebView lesson embedding (fun-talk-web dev server).
# Physical devices should use your LAN IP, e.g. http://192.168.1.108:19001
EXPO_PUBLIC_WEB_BASE_URL=http://localhost:19001

# OSS base URL for large/static remote assets (backgrounds, lesson media).
EXPO_PUBLIC_OSS_BASE_URL=https://fun-talk-file.oss-cn-beijing.aliyuncs.com

# Optional override for static assets when not bundled locally.
# EXPO_PUBLIC_ASSET_BASE_URL=https://ai-fun-talk.com

# Expo dev server runs on port 19002 (see package.json scripts).

# WeChat Open Platform app id (native login).
EXPO_PUBLIC_WECHAT_APP_ID=wx4f3da33035cc1d14
EXPO_PUBLIC_WECHAT_UNIVERSAL_LINK=https://ai-fun-talk.com/app/
